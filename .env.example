# ── LLM configuration (provider-agnostic via langchain init_chat_model) ──
# Provider is inferred from LLM_MODEL when using the "provider:model" form,
# or set LLM_PROVIDER explicitly. Examples:
#   LLM_PROVIDER=openai          LLM_MODEL=gpt-4o-mini
#   LLM_PROVIDER=anthropic       LLM_MODEL=claude-3-5-sonnet-latest
#   LLM_PROVIDER=ollama          LLM_MODEL=llama3.1
#   LLM_PROVIDER=google_genai    LLM_MODEL=gemini-2.0-flash      (AI Studio API key)
#   LLM_PROVIDER=google_vertexai LLM_MODEL=gemini-2.0-flash-001  (Vertex AI / GCP)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Provider API keys (set the one matching LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Gemini via AI Studio (LLM_PROVIDER=google_genai):
#   pip install ".[google-genai]"  and get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Google Gemini via Vertex AI (LLM_PROVIDER=google_vertexai):
#   pip install ".[google-vertexai]"  and authenticate with `gcloud auth application-default login`
#   or point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# ── Scholarly source configuration ──
# A contact email enables the faster "polite pool" for Crossref / OpenAlex
# and is good etiquette for NIH E-utilities.
CONTACT_EMAIL=you@example.com

# Optional: raises Semantic Scholar rate limits (works without it, just slower)
SEMANTIC_SCHOLAR_API_KEY=

# ── Run tuning ──
# Max papers fetched per source per domain
MAX_RESULTS_PER_SOURCE=8
# Number of domain swarms the orchestrator may create
MAX_DOMAINS=4
# Number of competing hypotheses to generate
NUM_HYPOTHESES=8
# Directory where run artifacts are persisted
ARTIFACTS_DIR=artifacts

# ── Layer 3 (In-Silico Validation) — AS-ALD surface reactivity ──
# Max iterations of the Reflection closed-loop (bounds the agentic refinement loop)
MAX_VALIDATION_ITERS=2

# Compute tier: 0 = pure-python literature/xTB priors (default, no GPU),
#               1 = foundation MLIP (MACE) adsorption energies, 2 = + spot-checks
COMPUTE_TIER=0
# Tier-1 MLIP settings (only used when COMPUTE_TIER >= 1)
MLIP_MODEL=mace-mp
MLIP_DEVICE=auto            # auto | cuda | mps | cpu (MACE float64 unsupported on mps)
# ALD process temperature (K) for the coverage / blocking model
ALD_TEMPERATURE_K=423.0
# Slabs generated per surface condition (ensemble size)
SURFACE_ENSEMBLE_N=5
# Human-editable inhibitor/precursor selection criteria + candidate library
SELECTION_CRITERIA_PATH=selection_criteria.md
# Prior source precedence for the selection agent:
#   auto   = KG-mined literature priors win over selection_criteria.md (no manual input needed)
#   manual = selection_criteria.md wins (edit that file to steer the agent)
PRIORS_SOURCE=auto
